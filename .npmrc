# Hoist Prisma packages so all workspace packages can resolve @prisma/client
public-hoist-pattern[]=@prisma/*

# Allow native/generated packages to run build scripts (pnpm v10 requires explicit allowlist)
onlyBuiltDependencies[]=@prisma/client
onlyBuiltDependencies[]=@prisma/engines
onlyBuiltDependencies[]=@scarf/scarf
onlyBuiltDependencies[]=@swc/core
onlyBuiltDependencies[]=bcrypt
onlyBuiltDependencies[]=esbuild
onlyBuiltDependencies[]=msgpackr-extract
onlyBuiltDependencies[]=prisma
onlyBuiltDependencies[]=sharp
