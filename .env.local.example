# ======================================
# LOCAL PostgreSQL Configuration
# ======================================
# Use these settings AFTER running the migration

# Local PostgreSQL (Docker)
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/submitheses?schema=public"
DIRECT_URL="postgresql://postgres:postgres@localhost:5432/submitheses"

# If backend runs in Docker, use service name instead of localhost:
# DATABASE_URL="postgresql://postgres:postgres@postgres:5432/submitheses?schema=public"
# DIRECT_URL="postgresql://postgres:postgres@postgres:5432/submitheses"

# ======================================
# ORIGINAL Supabase Configuration
# ======================================
# Keep these commented out as backup
# DATABASE_URL="postgresql://REDACTED_SUPABASE_HOST:REDACTED_DB_PASSWORD@aws-1-us-east-2.pooler.supabase.com:6543/postgres?pgbouncer=true&connect_timeout=10&pool_timeout=10"
# DIRECT_URL="postgresql://REDACTED_SUPABASE_HOST:REDACTED_DB_PASSWORD@aws-1-us-east-2.pooler.supabase.com:5432/postgres"

# ======================================
# JWT Secrets (Keep these)
# ======================================
JWT_ACCESS_SECRET=REDACTED_SECRET
JWT_REFRESH_SECRET=REDACTED_SECRET
JWT_ISSUER=submit-theses

# ======================================
# Redis (Keep these)
# ======================================
REDIS_URL=redis://localhost:6379
REDIS_ENABLED=true

# ======================================
# Email Configuration (SMTP)
# ======================================
# SMTP server configuration for sending invitation emails
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password
SMTP_FROM_NAME=SumbiTheses System
SMTP_FROM_EMAIL=noreply@yourapp.com

# ======================================
# Application URL
# ======================================
# Base URL for generating invitation links
# In production, this MUST be HTTPS
APP_URL=http://localhost:3000
