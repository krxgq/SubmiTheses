# ======================================
# LOCAL PostgreSQL Configuration
# ======================================
# Use these settings AFTER running the migration

# Local PostgreSQL (Docker)
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/submitheses?schema=public"
DIRECT_URL="postgresql://postgres:postgres@localhost:5432/submitheses"

# If backend runs in Docker, use service name instead of localhost:
# DATABASE_URL="postgresql://postgres:postgres@postgres:5432/submitheses?schema=public"
# DIRECT_URL="postgresql://postgres:postgres@postgres:5432/submitheses"

# ======================================
# JWT Secrets (generate your own with: openssl rand -base64 64)
# ======================================
JWT_ACCESS_SECRET=your-access-secret-generate-with-openssl
JWT_REFRESH_SECRET=your-refresh-secret-generate-with-openssl-MUST-BE-DIFFERENT
JWT_ISSUER=sumbi-theses

# ======================================
# Redis (Keep these)
# ======================================
REDIS_URL=redis://localhost:6379
REDIS_ENABLED=true

# ======================================
# Email Configuration (SMTP)
# ======================================
# SMTP server configuration for sending invitation emails
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password
SMTP_FROM_NAME=SumbiTheses System
SMTP_FROM_EMAIL=noreply@yourapp.com

# ======================================
# S3-Compatible Storage (Garage)
# ======================================
# Point to local Garage instance (Docker) or leave S3_ENDPOINT empty for AWS S3
S3_ENDPOINT=http://localhost:3900
# Public URL the browser uses for pre-signed uploads/downloads
S3_PUBLIC_ENDPOINT=http://localhost:3900
AWS_REGION=garage
AWS_ACCESS_KEY_ID=your-garage-access-key
AWS_SECRET_ACCESS_KEY=your-garage-secret-key
AWS_S3_BUCKET_ATTACHMENTS=sumbitheses-attachments
AWS_S3_BUCKET_AVATARS=sumbitheses-avatars
USE_S3_STORAGE=true

# ======================================
# Microsoft OAuth (Azure AD / Entra ID)
# ======================================
MICROSOFT_CLIENT_ID=your-azure-app-client-id
MICROSOFT_CLIENT_SECRET=your-azure-app-client-secret
MICROSOFT_TENANT_ID=your-azure-tenant-id
MICROSOFT_REDIRECT_URI=http://localhost:5000/api/auth/microsoft/callback

# ======================================
# Application URL
# ======================================
# Base URL for generating invitation links
# In production, this MUST be HTTPS
APP_URL=http://localhost:3000
