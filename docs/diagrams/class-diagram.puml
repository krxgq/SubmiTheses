@startuml class-diagram
' ============================================================
' SumbiTheses - Class Diagram (Implementation)
' OOP design with proper access modifiers and relationships
' ============================================================

skinparam classAttributeIconSize 0
skinparam class {
    BackgroundColor<<entity>> #E8F5E9
    BackgroundColor<<service>> #E3F2FD
    BackgroundColor<<controller>> #FFF3E0
    BackgroundColor<<middleware>> #F3E5F5
    BackgroundColor<<enum>> #FFEBEE
}
skinparam groupInheritance 2

' ==========================================
' ENUMERATIONS
' ==========================================

enum UserRole <<enum>> {
    admin
    teacher
    student
}

enum ProjectStatus <<enum>> {
    draft
    locked
    public
}

enum ProjectRole <<enum>> {
    supervisor
    opponent
}

enum AuthProvider <<enum>> {
    local
    microsoft
    both
}

' ==========================================
' ENTITY CLASSES (Data Models)
' ==========================================

class User <<entity>> {
    - id: UUID <<PK>>
    - role: UserRole
    - email: string <<unique>>
    - password_hash: string
    - first_name: string
    - last_name: string
    - avatar_url: string
    - class: string
    - auth_provider: AuthProvider
    - microsoft_id: string
    - email_verified: boolean
    - last_login: DateTime
    - password_reset_token: string
    - password_reset_expires: DateTime
    - year_id: BigInt <<FK>>
    - created_at: DateTime
    - updated_at: DateTime
    __
    + getFullName(): string
    + isAdmin(): boolean
    + isTeacher(): boolean
    + isStudent(): boolean
    + hasLocalAuth(): boolean
    + hasMicrosoftAuth(): boolean
}

class Project <<entity>> {
    - id: BigInt <<PK>>
    - title: string
    - subject: string
    - description: string
    - main_documentation: string
    - status: ProjectStatus
    - supervisor_id: UUID <<FK>>
    - opponent_id: UUID <<FK>>
    - student_id: UUID <<FK>>
    - year_id: BigInt <<FK>>
    - subject_id: BigInt <<FK>>
    - lock_reason: string
    - locked_at: DateTime
    - locked_by: UUID <<FK>>
    - reminders_sent: int[]
    - updated_at: DateTime
    __
    + isDraft(): boolean
    + isLocked(): boolean
    + isPublic(): boolean
    + canBeEditedBy(user: User): boolean
    + canBeDeletedBy(user: User): boolean
}

class ProjectDescription <<entity>> {
    - id: BigInt <<PK>>
    - project_id: BigInt <<FK, unique>>
    - topic: string
    - project_goal: string
    - specification: string
    - schedule: JSON
    - needed_output: string[]
    - grading_criteria: string[]
    - grading_notes: string
    - created_at: DateTime
    - updated_at: DateTime
}

class Grade <<entity>> {
    - id: BigInt <<PK>>
    - value: BigInt
    - project_id: BigInt <<FK>>
    - reviewer_id: UUID <<FK>>
    - year_id: BigInt <<FK>>
    - scale_id: BigInt <<FK>>
    - created_at: DateTime
}

class Review <<entity>> {
    - id: BigInt <<PK>>
    - project_id: BigInt <<FK>>
    - reviewer_id: UUID <<FK>>
    - comments: string
    - submitted_at: DateTime
    - updated_at: DateTime
}

class Scale <<entity>> {
    - id: BigInt <<PK>>
    - name: string
    - desc: string
    - maxVal: BigInt
    - created_at: DateTime
}

class ScaleSet <<entity>> {
    - id: BigInt <<PK>>
    - name: string
    - year_id: BigInt <<FK>>
    - project_role: ProjectRole
    - created_at: DateTime
}

class ScaleSetScale <<entity>> {
    - id: BigInt <<PK>>
    - scale_set_id: BigInt <<FK>>
    - scale_id: BigInt <<FK>>
    - weight: smallint
    - display_order: smallint
    - created_at: DateTime
}

class Attachment <<entity>> {
    - id: BigInt <<PK>>
    - project_id: BigInt <<FK>>
    - filename: string
    - storage_path: string
    - description: string
    - uploaded_at: DateTime
    - updated_at: DateTime
}

class ExternalLink <<entity>> {
    - id: BigInt <<PK>>
    - project_id: BigInt <<FK>>
    - url: string
    - title: string
    - description: string
    - added_at: DateTime
    - updated_at: DateTime
}

class ProjectSignup <<entity>> {
    - id: BigInt <<PK>>
    - project_id: BigInt <<FK>>
    - student_id: UUID <<FK>>
    - created_at: DateTime
}

class ActivityLog <<entity>> {
    - id: BigInt <<PK>>
    - project_id: BigInt <<FK>>
    - user_id: UUID <<FK>>
    - action_type: string
    - description: string
    - metadata: JSON
    - created_at: DateTime
}

class Notification <<entity>> {
    - id: BigInt <<PK>>
    - user_id: UUID <<FK>>
    - type: string
    - title: string
    - message: string
    - read: boolean
    - metadata: JSON
    - created_at: DateTime
    __
    + markAsRead(): void
}

class Year <<entity>> {
    - id: BigInt <<PK>>
    - name: string <<unique>>
    - assignment_date: DateTime
    - submission_date: DateTime
    - feedback_date: DateTime
    - deadline_reminder_days: int[]
    - created_at: DateTime
    __
    + isDeadlinePassed(): boolean
    + getDaysUntilSubmission(): int
}

class Subject <<entity>> {
    - id: BigInt <<PK>>
    - name: string <<unique>>
    - description: string
    - is_active: boolean
    - created_at: DateTime
    - updated_at: DateTime
}

' ==========================================
' SERVICE CLASSES (Business Logic)
' ==========================================

class AuthService <<service>> {
    - prisma: PrismaClient
    __
    + register(email, password, role, name): User
    + registerWithoutPassword(email, role, name): User
    + login(email, password): TokenPair
    + loginOrCreateFromMicrosoft(msUser): TokenPair
    + setPasswordForMicrosoftUser(userId, password): void
    + linkMicrosoftAccount(userId, msId, email): void
    - hashPassword(password): string
    - verifyPassword(password, hash): boolean
}

class JWTService <<service>> {
    - accessTokenSecret: string
    - refreshTokenSecret: string
    - accessTokenExpiry: string
    - refreshTokenExpiry: string
    __
    + generateTokens(user): TokenPair
    + verifyAccessToken(token): JWTPayload
    + verifyRefreshToken(token): JWTPayload
    + decodeToken(token): JWTPayload
}

class MicrosoftOAuthService <<service>> {
    - clientId: string
    - tenantId: string
    - redirectUri: string
    __
    + generatePKCE(): PKCEPair
    + getAuthorizationUrl(state, codeChallenge): string
    + exchangeCodeForTokens(code, codeVerifier): TokenResponse
    + validateAndExtractUser(idToken): MicrosoftUser
    - validateDomain(email): UserRole
}

class ProjectService <<service>> {
    - prisma: PrismaClient
    __
    + createProject(data): Project
    + getProjectById(id): Project
    + getAllProjects(filters): Project[]
    + updateProject(id, data): Project
    + deleteProject(id): void
    + assignStudentToProject(projectId, studentId): Project
    + lockProject(id, userId, reason): Project
    + unlockProject(id): Project
    + publishProject(id): Project
    + bulkPublish(ids): number
    + autoLockExpiredProjects(): void
    - transformProjectResponse(prismaProject): Project
}

class GradingService <<service>> {
    - prisma: PrismaClient
    __
    + getScaleSetForTeacher(projectId, userId): ScaleSet
    + getTeacherGrades(projectId, userId): Grade[]
    + submitGrades(projectId, userId, grades, review?): void
    + getAllProjectGrades(projectId): Grade[]
}

class S3Service <<service>> {
    - s3Client: S3Client
    - attachmentBucket: string
    - avatarBucket: string
    __
    + generateAttachmentUploadUrl(projectId, filename, type): PresignedUrl
    + generateAvatarUploadUrl(userId, filename, type): PresignedUrl
    + generateDownloadUrl(storagePath): PresignedUrl
    - validateFileType(filename, mimeType): boolean
    - validateFileSize(size): boolean
    - generateStorageKey(prefix, id, filename): string
}

class EmailService <<service>> {
    - transporter: Transporter
    - isDevelopment: boolean
    __
    + sendInvitationEmail(email, token, name): void
    + sendPasswordResetEmail(email, token, name): void
    - createTransporter(): Transporter
    - renderTemplate(template, data): string
}

class NotificationService <<service>> {
    - prisma: PrismaClient
    - redis: RedisClient
    __
    + createNotification(userId, type, title, message, metadata?): Notification
    + createNotifications(notifications): void
    + getUserNotifications(userId, limit): Notification[]
    + markAsRead(notificationId): void
    + getUnreadCount(userId): number
    - invalidateCache(userId): void
}

class ActivityLogService <<service>> {
    - prisma: PrismaClient
    __
    + log(projectId, userId, action, description, metadata?): ActivityLog
    + getRecentActivities(projectId, limit): ActivityLog[]
}

class ProjectSignupService <<service>> {
    - prisma: PrismaClient
    __
    + signupStudent(projectId, studentId): ProjectSignup
    + cancelSignup(projectId, studentId): void
    + getProjectSignups(projectId): ProjectSignup[]
    + checkSignupStatus(projectId, studentId): boolean
}

class DeadlineSchedulerService <<service>> {
    - prisma: PrismaClient
    __
    + scheduleDeadlineReminders(): void
    + checkAndSendReminders(): void
    - shouldSendReminder(project, year, daysLeft): boolean
}

' ==========================================
' CONTROLLER CLASSES (Request Handlers)
' ==========================================

class AuthController <<controller>> {
    __
    + login(req, res): void
    + register(req, res): void
    + logout(req, res): void
    + validateSession(req, res): void
    + getSession(req, res): void
    + refreshToken(req, res): void
    + getUser(req, res): void
    + setPassword(req, res): void
    + microsoftAuth(req, res): void
    + microsoftCallback(req, res): void
    + microsoftLink(req, res): void
}

class ProjectsController <<controller>> {
    __
    + getAll(req, res): void
    + getById(req, res): void
    + getPublicProjects(req, res): void
    + create(req, res): void
    + update(req, res): void
    + delete(req, res): void
    + updateStatus(req, res): void
    + bulkPublish(req, res): void
    + autoLock(req, res): void
    + assignStudent(req, res): void
    + getActivities(req, res): void
}

class UsersController <<controller>> {
    __
    + getAll(req, res): void
    + getById(req, res): void
    + getByRole(req, res): void
    + create(req, res): void
    + update(req, res): void
    + delete(req, res): void
    + updateRole(req, res): void
    + bulkAssignYear(req, res): void
    + resendInvitation(req, res): void
    + resetPassword(req, res): void
    + validateInvitation(req, res): void
    + setupPassword(req, res): void
}

class GradingController <<controller>> {
    __
    + getScaleSet(req, res): void
    + getMyGrades(req, res): void
    + submitGrades(req, res): void
    + getAllGrades(req, res): void
}

' ==========================================
' MIDDLEWARE CLASSES
' ==========================================

class AuthMiddleware <<middleware>> {
    __
    + authenticate(req, res, next): void
    + requireAdmin(req, res, next): void
    + requireProjectAccess(req, res, next): void
    + requireProjectModify(req, res, next): void
    + requireProjectDelete(req, res, next): void
    + requireGradingAccess(req, res, next): void
    + requireSignupAccess(req, res, next): void
    + requireSignupsViewAccess(req, res, next): void
}

class RateLimitMiddleware <<middleware>> {
    __
    + generalWriteLimit(): Middleware
    + loginLimit(): Middleware
    + registrationLimit(): Middleware
    + sensitiveOperationLimit(): Middleware
    + destructiveLimit(): Middleware
    + bulkOperationLimit(): Middleware
    + invitationLimit(): Middleware
}

class CSRFMiddleware <<middleware>> {
    __
    + validateCSRF(req, res, next): void
}

class ValidationSchemas <<middleware>> {
    __
    + loginSchema: ZodSchema
    + registerSchema: ZodSchema
    + createProjectSchema: ZodSchema
    + updateProjectSchema: ZodSchema
    + submitGradesSchema: ZodSchema
    + createUserSchema: ZodSchema
    + updateUserSchema: ZodSchema
}

' ==========================================
' ENTITY RELATIONSHIPS
' ==========================================

' -- Composition (filled diamond): part cannot exist without whole --
' Deleting a project cascade-deletes these
Project "1" *-down- "0..1" ProjectDescription : contains >
Project "1" *-down- "0..*" Grade : has >
Project "1" *-down- "0..*" Review : has >
Project "1" *-down- "0..*" Attachment : has >
Project "1" *-down- "0..*" ExternalLink : has >
Project "1" *-down- "0..*" ActivityLog : logs >
Project "1" *-down- "0..*" ProjectSignup : has >

' Deleting a user cascade-deletes their notifications
User "1" *-- "0..*" Notification : receives >

' Scale set owns its scale assignments
ScaleSet "1" *-- "0..*" ScaleSetScale : contains >

' -- Aggregation (empty diamond): parts exist independently --
Year "1" o-- "0..*" Project : groups >
Year "1" o-- "0..*" User : groups >
Year "1" o-- "0..*" ScaleSet : configures >
Year "1" o-- "0..*" Grade : tracks >
Subject "1" o-- "0..*" Project : categorizes >

' -- Association: users relate to projects in multiple roles --
User "1" -- "0..*" Project : supervises >
User "1" -- "0..*" Project : opposes >
User "1" -- "0..*" Project : is student of >
User "1" -- "0..*" Project : locked by >
User "1" -- "0..*" Grade : gives >
User "1" -- "0..*" Review : writes >
User "1" -- "0..*" ProjectSignup : signs up for >
User "1" -- "0..*" ActivityLog : performs >

' Grade references a scale
Grade "0..*" --> "0..1" Scale : uses >

' ScaleSetScale references a scale
ScaleSetScale "0..*" --> "1" Scale : references >

' -- Enum usage --
User --> UserRole
User --> AuthProvider
Project --> ProjectStatus
ScaleSet --> ProjectRole

' ==========================================
' SERVICE LAYER DEPENDENCIES
' ==========================================

' Controller -> Service (association: controllers depend on services)
AuthController ..> AuthService : uses >
ProjectsController ..> ProjectService : uses >
UsersController ..> AuthService : uses >
UsersController ..> EmailService : uses >
GradingController ..> GradingService : uses >

' Service -> Service (dependency: services collaborate)
AuthService ..> JWTService : uses >
AuthService ..> MicrosoftOAuthService : uses >
AuthService ..> EmailService : uses >
ProjectService ..> ActivityLogService : uses >
ProjectService ..> NotificationService : uses >
GradingService ..> NotificationService : uses >
GradingService ..> ActivityLogService : uses >
DeadlineSchedulerService ..> NotificationService : uses >
DeadlineSchedulerService ..> ProjectService : uses >
ProjectSignupService ..> NotificationService : uses >
S3Service ..> Attachment : manages >

' Middleware -> Service
AuthMiddleware ..> JWTService : verifies tokens >

@enduml
