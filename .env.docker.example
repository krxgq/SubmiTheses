# Docker Environment Variables
# Copy this to .env and fill in your values

# JWT Configuration (Generate secure random strings for production!)
# You can generate secure secrets with: openssl rand -base64 32
JWT_ACCESS_SECRET=your-secret-access-key-change-in-production
JWT_REFRESH_SECRET=your-secret-refresh-key-change-in-production
JWT_ISSUER=submit-theses

# Database Configuration
# For local Docker setup (uses PostgreSQL container):
DATABASE_URL=postgresql://postgres:postgres@postgres:5432/submitheses?schema=public
DIRECT_URL=postgresql://postgres:postgres@postgres:5432/submitheses

# For remote PostgreSQL (Supabase or other hosted database):
# DATABASE_URL=postgresql://user:password@host:port/database?schema=public
# DIRECT_URL=postgresql://user:password@host:port/database

# SMTP Configuration for Email Notifications
# Default: Mailpit (development/testing SMTP server with web UI at http://localhost:8025)
SMTP_HOST=mailpit
SMTP_PORT=1025
SMTP_SECURE=false
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM_NAME=SumbiTheses System
SMTP_FROM_EMAIL=noreply@submitheses.local

# For production, replace with real SMTP service (e.g., Gmail):
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_USER=your-email@gmail.com
# SMTP_PASSWORD=your-app-password
# SMTP_FROM_NAME=SumbiTheses System
# SMTP_FROM_EMAIL=noreply@yourdomain.com

# Application URL (used in email links)
APP_URL=http://localhost:3000

# ======================================
# Microsoft OAuth (Azure AD / Entra ID)
# ======================================
MICROSOFT_CLIENT_ID=your-azure-app-client-id
MICROSOFT_CLIENT_SECRET=your-azure-app-client-secret
MICROSOFT_TENANT_ID=your-azure-tenant-id
MICROSOFT_REDIRECT_URI=http://localhost:5000/api/auth/microsoft/callback

# Redis Configuration
REDIS_URL=redis://redis:6379
REDIS_ENABLED=true

# ======================================
# S3-Compatible Storage (Garage)
# ======================================
# Garage runs as a Docker service — credentials are created after first startup.
# See post-deploy setup commands in docker-compose.yml comments.
S3_ENDPOINT=http://garage:3900
# Public URL the browser uses for pre-signed uploads/downloads (must be reachable from host)
S3_PUBLIC_ENDPOINT=http://localhost:3900
AWS_REGION=garage
AWS_ACCESS_KEY_ID=your-garage-access-key
AWS_SECRET_ACCESS_KEY=your-garage-secret-key
AWS_S3_BUCKET_ATTACHMENTS=sumbitheses-attachments
AWS_S3_BUCKET_AVATARS=sumbitheses-avatars
USE_S3_STORAGE=true
