generator client {
  provider = "prisma-client-js"
}

generator zod {
  provider               = "zod-prisma-types"
  output                 = "../../packages/shared-types/src/generated"
  addIncludeType         = "true"
  addInputTypeValidation = "true"
  addSelectType          = "true"
  createInputTypes       = "true"
  createModelTypes       = "true"
  useMultipleFiles       = "true"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
  schemas   = ["public"]
}

model activity_logs {
  id          BigInt   @id @default(autoincrement())
  project_id  BigInt
  user_id     String   @db.Uuid
  action_type String   @db.VarChar(50)
  description String   @db.VarChar(255)
  metadata    Json?
  created_at  DateTime @default(now()) @db.Timestamptz(6)
  projects    projects @relation(fields: [project_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  users       users    @relation(fields: [user_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([created_at])
  @@index([project_id])
  @@schema("public")
}

model attachments {
  id           BigInt    @id @default(autoincrement())
  project_id   BigInt?
  filename     String    @db.VarChar
  storage_path String    @db.VarChar
  description  String?   @db.VarChar
  uploaded_at  DateTime  @default(now()) @db.Timestamptz(6)
  updated_at   DateTime  @db.Timestamptz(6)
  projects     projects? @relation(fields: [project_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([project_id])
  @@schema("public")
}

model external_links {
  id          BigInt    @id @default(autoincrement())
  project_id  BigInt?
  url         String?   @db.VarChar
  title       String?   @db.VarChar
  description String?   @db.VarChar
  added_at    DateTime  @default(now()) @db.Timestamptz(6)
  updated_at  DateTime  @db.Timestamptz(6)
  projects    projects? @relation(fields: [project_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([project_id])
  @@schema("public")
}

model grades {
  id          BigInt   @id(map: "grade_pkey") @default(autoincrement())
  value       BigInt
  year_id     BigInt
  project_id  BigInt
  reviewer_id String   @db.Uuid
  created_at  DateTime @default(now()) @db.Timestamptz(6)
  scale_id    BigInt?
  users       users    @relation(fields: [reviewer_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "fk_grades_reviewer")
  projects    projects @relation(fields: [project_id], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "grade_project_id_fkey")
  years       years    @relation(fields: [year_id], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "grade_year_id_fkey")
  scales      scales?  @relation(fields: [scale_id], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@index([scale_id])
  @@index([reviewer_id], map: "idx_grades_reviewer")
  @@schema("public")
}

model notifications {
  id         BigInt   @id @default(autoincrement())
  user_id    String   @db.Uuid
  type       String   @db.VarChar(50)
  title      String   @db.VarChar(255)
  message    String   @db.VarChar(500)
  read       Boolean  @default(false)
  metadata   Json?
  created_at DateTime @default(now()) @db.Timestamptz(6)
  users      users    @relation(fields: [user_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([created_at], map: "idx_notifications_created_at")
  @@index([read], map: "idx_notifications_read")
  @@index([user_id], map: "idx_notifications_user_id")
  @@schema("public")
}

model project_descriptions {
  id               BigInt   @id @default(autoincrement())
  project_id       BigInt   @unique
  topic            String?
  project_goal     String?
  specification    String?
  schedule         Json?
  needed_output    String[]
  grading_criteria String[]
  grading_notes    String?
  created_at       DateTime @default(now()) @db.Timestamptz(6)
  updated_at       DateTime @default(now()) @db.Timestamptz(6)
  projects         projects @relation(fields: [project_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "fk_project_descriptions_project")

  @@index([project_id], map: "idx_project_descriptions_project_id")
  @@index([schedule], map: "idx_project_descriptions_schedule", type: Gin)
  @@schema("public")
}

model project_signups {
  id         BigInt   @id @default(autoincrement())
  project_id BigInt
  student_id String   @db.Uuid
  created_at DateTime @default(now()) @db.Timestamptz(6)
  projects   projects @relation(fields: [project_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  users      users    @relation(fields: [student_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@unique([project_id, student_id])
  @@index([project_id])
  @@index([student_id])
  @@schema("public")
}

/// This model or at least one of its fields has comments in the database, and requires an additional setup for migrations: Read more: https://pris.ly/d/database-comments
model projects {
  id                                  BigInt                @id @default(autoincrement())
  title                               String                @db.VarChar
  supervisor_id                       String?               @db.Uuid
  opponent_id                         String?               @db.Uuid
  subject                             String                @db.VarChar
  description                         String?               @db.VarChar
  main_documentation                  String?               @db.VarChar
  updated_at                          DateTime              @default(now()) @db.Timestamptz(6)
  student_id                          String?               @db.Uuid
  status                              status?               @default(draft)
  year_id                             BigInt?
  subject_id                          BigInt?
  lock_reason                         String?               @db.VarChar(255)
  locked_at                           DateTime?             @db.Timestamptz(6)
  locked_by                           String?               @db.Uuid
  reminders_sent                      Int[]                 @default([])
  activity_logs                       activity_logs[]
  attachments                         attachments[]
  external_links                      external_links[]
  grades                              grades[]
  project_descriptions                project_descriptions?
  project_signups                     project_signups[]
  users_projects_locked_byTousers     users?                @relation("projects_locked_byTousers", fields: [locked_by], references: [id], onUpdate: NoAction, map: "fk_projects_locked_by")
  users_projects_opponent_idTousers   users?                @relation("projects_opponent_idTousers", fields: [opponent_id], references: [id], onUpdate: NoAction, map: "fk_projects_opponent")
  users_projects_student_idTousers    users?                @relation("projects_student_idTousers", fields: [student_id], references: [id], onUpdate: NoAction, map: "fk_projects_student")
  users_projects_supervisor_idTousers users?                @relation("projects_supervisor_idTousers", fields: [supervisor_id], references: [id], onUpdate: NoAction, map: "fk_projects_supervisor")
  years                               years?                @relation(fields: [year_id], references: [id], onUpdate: NoAction, map: "fk_projects_year")
  subjects                            subjects?             @relation(fields: [subject_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  reviews                             reviews[]

  @@index([locked_by], map: "idx_projects_locked_by")
  @@index([opponent_id], map: "idx_projects_opponent")
  @@index([reminders_sent], map: "idx_projects_reminders_sent", type: Gin)
  @@index([status], map: "idx_projects_status")
  @@index([student_id], map: "idx_projects_student")
  @@index([subject_id], map: "idx_projects_subject_id")
  @@index([supervisor_id], map: "idx_projects_supervisor")
  @@index([title(ops: raw("gin_trgm_ops"))], map: "idx_projects_title_trgm", type: Gin)
  @@index([year_id], map: "idx_projects_year_id")
  @@schema("public")
}

model reviews {
  id           BigInt   @id @default(autoincrement())
  project_id   BigInt
  reviewer_id  String   @db.Uuid
  comments     String   @db.VarChar
  submitted_at DateTime @default(now()) @db.Timestamptz(6)
  updated_at   DateTime @db.Timestamptz(6)
  users        users    @relation(fields: [reviewer_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "fk_reviews_reviewer")
  projects     projects @relation(fields: [project_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([reviewer_id], map: "idx_reviews_reviewer")
  @@index([project_id])
  @@schema("public")
}

model scale_set_scales {
  id            BigInt     @id @default(autoincrement())
  scale_set_id  BigInt
  scale_id      BigInt
  weight        Int        @db.SmallInt
  display_order Int?       @db.SmallInt
  created_at    DateTime   @default(now()) @db.Timestamptz(6)
  scales        scales     @relation(fields: [scale_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  scale_sets    scale_sets @relation(fields: [scale_set_id], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@schema("public")
}

model scale_sets {
  id               BigInt             @id(map: "scale_set_pkey") @default(autoincrement())
  name             String?            @db.VarChar
  year_id          BigInt?
  created_at       DateTime           @default(now()) @db.Timestamptz(6)
  project_role     project_role?
  scale_set_scales scale_set_scales[]
  years            years?             @relation(fields: [year_id], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "scale_set_year_id_fkey")

  @@schema("public")
}

model scales {
  id               BigInt             @id(map: "scale_pkey") @default(autoincrement())
  maxVal           BigInt
  name             String
  desc             String?
  created_at       DateTime           @default(now()) @db.Timestamptz(6)
  grades           grades[]
  scale_set_scales scale_set_scales[]

  @@schema("public")
}

model subjects {
  id          BigInt     @id @default(autoincrement())
  description String?
  is_active   Boolean?   @default(true)
  created_at  DateTime?  @default(now()) @db.Timestamptz(6)
  updated_at  DateTime?  @default(now()) @db.Timestamptz(6)
  name        String     @unique @db.VarChar(255)
  projects    projects[]

  @@schema("public")
}

model users {
  id                                     String            @id @db.Uuid
  role                                   user_roles
  first_name                             String?           @db.VarChar
  last_name                              String?           @db.VarChar
  created_at                             DateTime          @default(now()) @db.Timestamptz(6)
  updated_at                             DateTime          @default(now()) @db.Timestamptz(6)
  email                                  String            @unique(map: "users_email_unique") @db.VarChar
  year_id                                BigInt?
  avatar_url                             String?           @db.VarChar
  password_hash                          String            @default("") @db.VarChar
  auth_provider                          String            @default("local") @db.VarChar(20)
  microsoft_id                           String?           @db.VarChar(255)
  email_verified                         Boolean           @default(false)
  email_verified_at                      DateTime?         @db.Timestamptz(6)
  password_reset_token                   String?           @db.VarChar
  password_reset_expires                 DateTime?         @db.Timestamptz(6)
  last_login                             DateTime?         @db.Timestamptz(6)
  class                                  String?           @db.VarChar(10)
  activity_logs                          activity_logs[]
  grades                                 grades[]
  notifications                          notifications[]
  project_signups                        project_signups[]
  projects_projects_locked_byTousers     projects[]        @relation("projects_locked_byTousers")
  projects_projects_opponent_idTousers   projects[]        @relation("projects_opponent_idTousers")
  projects_projects_student_idTousers    projects[]        @relation("projects_student_idTousers")
  projects_projects_supervisor_idTousers projects[]        @relation("projects_supervisor_idTousers")
  reviews                                reviews[]
  years                                  years?            @relation(fields: [year_id], references: [id], onUpdate: NoAction, map: "fk_users_year")

  @@index([microsoft_id], map: "idx_users_microsoft_id")
  @@index([email], map: "idx_users_email")
  @@index([email_verified], map: "idx_users_email_verified")
  @@index([password_reset_token], map: "idx_users_password_reset_token")
  @@index([role], map: "idx_users_role")
  @@index([year_id], map: "idx_users_year_id")
  @@schema("public")
}

/// This model or at least one of its fields has comments in the database, and requires an additional setup for migrations: Read more: https://pris.ly/d/database-comments
model years {
  id                     BigInt       @id(map: "year_pkey") @default(autoincrement())
  school_id              BigInt?
  assignment_date        DateTime?    @db.Timestamptz(6)
  submission_date        DateTime?    @db.Timestamptz(6)
  feedback_date          DateTime?    @db.Timestamptz(6)
  created_at             DateTime     @default(now()) @db.Timestamptz(6)
  name                   String?      @unique(map: "unique_year_name") @db.VarChar(50)
  deadline_reminder_days Int[]        @default([7, 3, 1])
  grades                 grades[]
  projects               projects[]
  scale_sets             scale_sets[]
  users                  users[]

  @@schema("public")
}

enum project_role {
  supervisor
  opponent

  @@schema("public")
}

enum status {
  draft
  locked
  public

  @@schema("public")
}

enum user_roles {
  admin
  teacher
  student

  @@schema("public")
}
